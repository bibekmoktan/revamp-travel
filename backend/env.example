# Environment Configuration
NODE_ENV=development
PORT=3002

# Database
MONGO_URL=mongodb://localhost:27017/travel-nepal

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters
JWT_REFRESH_EXPIRE=30d

# Security
BCRYPT_ROUNDS=12

# CORS (Required in production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Cloudinary (Required in production)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Redis (Optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Frontend URL (used for OAuth redirects)
FRONTEND_URL=http://localhost:3000

# OAuth — Google  (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Facebook  (https://developers.facebook.com)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# OAuth — Apple  (https://developer.apple.com → Services → Sign In with Apple)
APPLE_CLIENT_ID=
